// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime @default(now())

  // Relationships
  groupsCreated    Group[]       @relation("GroupCreator")
  groupMemberships GroupMember[]
  expensesPaid     Expense[]     @relation("ExpensePayer")
  expensesCreated  Expense[]     @relation("ExpenseCreator")
  expenseParticipations ExpenseParticipant[]
  settlementsPaid  Settlement[]  @relation("SettlementPayer")
  settlementsRcvd  Settlement[]  @relation("SettlementReceiver")
  settlementsCrtd  Settlement[]  @relation("SettlementCreator")
  importResolutions ImportMemberResolution[]
}

model Group {
  id        Int           @id @default(autoincrement())
  name      String
  createdBy Int
  createdAt DateTime      @default(now())
  
  // Relationships
  creator   User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members   GroupMember[]
  expenses  Expense[]
  settlements Settlement[]
  imports     ImportSession[]
}

model GroupMember {
  id       Int       @id @default(autoincrement())
  groupId  Int
  userId   Int
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  // Relationships
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

model Expense {
  id          Int       @id @default(autoincrement())
  description String
  amount      Float
  currency    String
  expenseDate DateTime
  splitType   SplitType
  notes       String?
  groupId     Int
  payerId     Int
  createdBy   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [payerId], references: [id])
  creator      User                 @relation("ExpenseCreator", fields: [createdBy], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id        Int      @id @default(autoincrement())
  expenseId Int
  userId    Int
  shareValue Float?  // Null for EQUAL splits, exact amount or percentage otherwise

  // Relationships
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settlement {
  id             Int      @id @default(autoincrement())
  amount         Float
  settlementDate DateTime
  notes          String?
  groupId        Int
  payerId        Int
  receiverId     Int
  createdBy      Int
  createdAt      DateTime @default(now())

  // Relationships
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])
  creator  User  @relation("SettlementCreator", fields: [createdBy], references: [id])
}

model ImportSession {
  id         String   @id @default(uuid())
  groupId    Int
  rawCsvData Json
  createdAt  DateTime @default(now())

  // Relationships
  group      Group                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resolutions ImportMemberResolution[]
}

enum ResolutionType {
  MAP_EXISTING
  CREATE_NEW_MEMBER
  CREATE_GUEST
}

model ImportMemberResolution {
  id              Int            @id @default(autoincrement())
  importSessionId String
  csvMemberName   String
  resolutionType  ResolutionType
  resolvedUserId  Int?
  guestName       String?
  createdAt       DateTime       @default(now())

  // Relationships
  session         ImportSession  @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  resolvedUser    User?          @relation(fields: [resolvedUserId], references: [id])

  @@unique([importSessionId, csvMemberName])
}